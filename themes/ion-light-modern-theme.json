  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C8C8C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#067D17"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.quoted constant.character.escape"
      ],
      "settings": {
        "foreground": "#0037A6"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#1750EB"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#0033B3"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#0033B3"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of"
      ],
      "settings": {
        "foreground": "#0033B3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0033B3"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.ternary",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.terminator",
        "punctuation.separator",
        "punctuation.section",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Function Declaration",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.method.identifier entity.name.function"
      ],
      "settings": {
        "foreground": "#00627A"
      }
    },
    {
      "name": "Method Declaration",
      "scope": [
        "meta.method entity.name.function",
        "meta.method.declaration entity.name.function"
      ],
      "settings": {
        "foreground": "#00627A"
      }
    },
    {
      "name": "Class/Type Declaration",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Interface",
      "scope": [
        "entity.name.type.interface",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Enum",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Namespace/Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.language"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Property/Field",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#871094"
      }
    },
    {
      "name": "Type Parameter",
      "scope": [
        "entity.name.type.parameter",
        "storage.type.generic"
      ],
      "settings": {
        "foreground": "#007E8A"
      }
    },
    {
      "name": "Decorator/Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "punctuation.definition.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#9E880D"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#0033B3"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Library/Framework",
      "scope": [
        "support.function.builtin",
        "support.variable.dom",
        "support.constant"
      ],
      "settings": {
        "foreground": "#00627A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#DE1B2E"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "constant.character.escape.backslash.regexp"
      ],
      "settings": {
        "foreground": "#264EFF"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup - Heading",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#0033B3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup - Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
