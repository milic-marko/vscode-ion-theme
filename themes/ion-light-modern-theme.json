{
  "$schema": "vscode://schemas/color-theme",
  "name": "ion-light-modern",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#000000",
    "type": "#000000",
    "class": "#000000",
    "enum": "#000000",
    "interface": "#000000",
    "struct": "#000000",
